<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/layout_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="?colorPrimaryContainer"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_status_icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="?colorSurface"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_mic_24px"
                        app:contentPadding="14dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full"
                        app:tint="?colorPrimary" />

                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="8dp"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/iv_status_icon"
                        app:layout_constraintTop_toTopOf="@+id/iv_status_icon"
                        tools:text="@string/voice_status_listening" />

                    <TextView
                        android:id="@+id/tv_status_detail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha=".82"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        app:layout_constraintEnd_toEndOf="@+id/tv_status"
                        app:layout_constraintStart_toStartOf="@+id/tv_status"
                        app:layout_constraintTop_toBottomOf="@+id/tv_status"
                        tools:text="@string/voice_status_listening_detail" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_voice_control"
                        style="@style/Widget.Material3.Button.Icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/start_voice_command"
                        app:icon="@drawable/ic_mic_24px"
                        app:layout_constraintStart_toStartOf="@+id/tv_status"
                        app:layout_constraintTop_toBottomOf="@+id/tv_status_detail" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_experience_book"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="?colorOutlineVariant"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!--
                      ~ icon 跟 title+subtitle 垂直居中（不包括 usage）；这样 usage 行可以自然延伸到下方，
                      ~ 整体文字块从 padding 顶部开始排，不会出现"icon 居中导致文字上方空白"的视觉错位。
                      -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_experience_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?colorSecondaryContainer"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_baseline_auto_awesome_24"
                        app:contentPadding="8dp"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_experience_subtitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_experience_title"
                        app:shapeAppearance="@style/ShapeAppearance.Material3.Corner.Full"
                        app:tint="?colorOnSecondaryContainer" />

                    <TextView
                        android:id="@+id/tv_experience_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/ai_experience_book_card_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        app:layout_constraintEnd_toStartOf="@+id/iv_experience_arrow"
                        app:layout_constraintStart_toEndOf="@+id/iv_experience_icon"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_experience_subtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:alpha=".72"
                        android:text="@string/ai_experience_book_card_subtitle"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        app:layout_constraintEnd_toEndOf="@+id/tv_experience_title"
                        app:layout_constraintStart_toStartOf="@+id/tv_experience_title"
                        app:layout_constraintTop_toBottomOf="@+id/tv_experience_title" />

                    <TextView
                        android:id="@+id/tv_experience_usage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:alpha=".82"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_experience_subtitle"
                        tools:text="已记录 12 条 · 占用 38 KB" />

                    <ImageView
                        android:id="@+id/iv_experience_arrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/ai_experience_book_card_title"
                        android:src="@drawable/ic_chevron_right_24px"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_experience_title"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_experience_title"
                        app:tint="?colorOnSurfaceVariant" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_text_command"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="?colorOutlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/text_command_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha=".72"
                        android:text="@string/text_command_caption"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_text_command"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/voice_command_text_input_hint"
                            app:boxBackgroundMode="outline">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/input_text_command"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:imeOptions="actionSend"
                                android:inputType="textMultiLine"
                                android:maxLines="3" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_send_text_command"
                            style="@style/Widget.Material3.Button.IconButton.Filled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:contentDescription="@string/send_text_command"
                            app:icon="@drawable/ic_baseline_send_24" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_latest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="?colorOutlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_latest_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/voice_latest_title"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

                    <TextView
                        android:id="@+id/tv_latest_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/voice_latest_text_empty"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

                    <TextView
                        android:id="@+id/tv_latest_command"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:alpha=".82"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:visibility="gone"
                        tools:text="解析命令：打开飞书"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/tv_latest_task"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha=".82"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:visibility="gone"
                        tools:text="匹配任务：打开飞书"
                        tools:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_records_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/voice_records_title"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="320dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_records"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:itemCount="5"
                    tools:listitem="@layout/item_voice_command_record" />

                <TextView
                    android:id="@+id/tv_records_empty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:alpha=".72"
                    android:text="@string/voice_records_empty"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    tools:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>
